# Leave WAY_SECRET_KEY unset to run in MOCK mode (no real API calls).
# Set all three to proxy the real Way API.
WAY_API=https://api.staging.letsway.com
WAY_BRAND_ID=
WAY_SECRET_KEY=

# Stripe publishable key matching the brand's paymentPlatform (safe client-side).
# Required only for live card payments via Stripe Elements.
STRIPE_PUBLISHABLE_KEY=
